# Copie para terraform.tfvars e preencha com seus valores

tenancy_ocid     = "ocid1.tenancy.oc1..XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
user_ocid        = "ocid1.user.oc1..XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
fingerprint      = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
private_key_path = "~/.oci/oci_api_key.pem"
region           = "sa-saopaulo-1"
compartment_ocid = "ocid1.tenancy.oc1..XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# OCIDs da rede (outputs do 00-foundation)
vcn_id           = "ocid1.vcn.oc1.sa-saopaulo-1.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
public_subnet_id  = "ocid1.subnet.oc1.sa-saopaulo-1.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
private_subnet_id = "ocid1.subnet.oc1.sa-saopaulo-1.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Node pool — ARM A1.Flex (2 nodes × 2 OCPUs × 12GB = free tier)
node_shape     = "VM.Standard.A1.Flex"
node_ocpus     = 2
node_memory_gb = 12
node_count     = 2
